---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Bodega - Inventory Management">
  <main class="container mx-auto px-4 py-16">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-5xl font-bold mb-6 bg-gradient-to-r from-blue-400 to-blue-600 bg-clip-text text-transparent">
        Welcome to Bodega
      </h1>
      <p class="text-xl text-zinc-400 mb-8">
        Modern inventory management for forward-thinking teams
      </p>
      <div class="inline-flex gap-4">
        <a 
          href="#" 
          class="px-6 py-3 bg-blue-600 hover:bg-blue-500 rounded-lg font-medium transition-colors shadow-[0_0_20px_rgba(37,99,235,0.3)]"
        >
          Get Started
        </a>
        <a 
          href="#" 
          class="px-6 py-3 bg-zinc-900/40 backdrop-blur-3xl hover:bg-zinc-800/40 rounded-lg font-medium transition-colors border border-white/5"
        >
          Learn More
        </a>
      </div>
    </div>
  </main>
</Layout>
