---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/astro/Navigation.astro';
import Footer from '../components/astro/Footer.astro';

import Hero from '../components/react/Hero';
import Features from '../components/react/Features';
import Steps from '../components/react/Steps';
import CTA from '../components/react/CTA';
---

<Layout title="Bodega - Inventory Management">
  <div class="min-h-screen bg-zinc-950 flex flex-col relative overflow-hidden">
    <Navigation />
    <main class="relative z-10 flex-1">
      <div class="flex flex-col items-center w-full overflow-hidden">
        <Hero client:load />
        <Features client:load />
        <Steps client:load />
        <CTA client:load />
      </div>
    </main>
    <Footer />
  </div>
</Layout>
