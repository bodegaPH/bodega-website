---
import SectionEyebrow from '../../components/ui/astro/SectionEyebrow.astro';
import OpBadge from '../../components/ui/astro/OpBadge.astro';
---

<section id="features" class="px-6 py-32 max-w-[1600px] w-full mx-auto relative z-10 bg-zinc-950">
  
  <!-- Strict Header (Tactical) -->
  <div class="mb-16 md:mb-24 flex flex-col md:flex-row md:items-end justify-between gap-8">
    <div class="border-l border-indigo-500 pl-6 border-solid">
      <SectionEyebrow class="mb-4">
        Global Operations
      </SectionEyebrow>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-light text-white leading-[1.1]">
        Logistics.<br/>Command & Control.
      </h2>
    </div>
    <p class="text-sm text-zinc-400 font-light max-w-md bg-zinc-900/50 p-4 border border-zinc-800 relative shadow-inner">
      <span class="absolute top-0 left-0 w-1.5 h-1.5 border-t border-l border-zinc-500"></span>
      Abandon spreadsheets. Monitor, trace, and control multi-facility inventory through a strict, high-fidelity command interface.
    </p>
  </div>

  <!-- Tactical Grid Layout -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    
    <!-- Panel 1: Global Node Network -->
    <div class="relative border border-white/5 bg-zinc-950 flex flex-col group overflow-hidden">
      <!-- Tactical Corner Accents -->
      <div class="absolute top-0 left-0 w-2 h-2 border-t border-l border-white/40"></div>
      <div class="absolute top-0 right-0 w-2 h-2 border-t border-r border-white/40"></div>
      <div class="absolute bottom-0 left-0 w-2 h-2 border-b border-l border-white/40"></div>
      <div class="absolute bottom-0 right-0 w-2 h-2 border-b border-r border-white/40"></div>

      <!-- Graphic Area: Vector Network -->
      <div class="relative border-b border-zinc-900 bg-zinc-900/20 flex flex-col justify-center h-[180px]">
        <svg class="w-full h-full object-contain p-4" viewBox="0 0 400 120" preserveAspectRatio="xMidYMid meet">
          <!-- Crisp grid lines -->
          <pattern id="dot-grid" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
            <rect x="0" y="0" width="1" height="1" fill="#3f3f46"></rect>
          </pattern>
          <rect x="0" y="0" width="400" height="120" fill="url(#dot-grid)"></rect>
          
          <!-- Hard Edge Paths -->
          <path d="M 50 60 L 150 20 L 250 60 L 350 30" fill="none" stroke="#52525b" stroke-width="1"></path>
          <path d="M 150 20 L 150 100 L 250 60" fill="none" stroke="#52525b" stroke-width="1"></path>
          
          <!-- Animated flow (Solid, NO GLOW) -->
          <path d="M 50 60 L 150 20 L 250 60 L 350 30" fill="none" stroke="#000000" stroke-width="3"></path>
          <path d="M 50 60 L 150 20 L 250 60 L 350 30" fill="none" stroke="#6366f1" stroke-width="1" stroke-dasharray="50 350" stroke-dashoffset="0">
            <animate attributeName="stroke-dashoffset" from="400" to="0" dur="3s" repeatCount="indefinite"></animate>
          </path>
          <path d="M 150 20 L 150 100 L 250 60" fill="none" stroke="#6366f1" stroke-width="1" stroke-dasharray="20 200" stroke-dashoffset="0">
            <animate attributeName="stroke-dashoffset" from="220" to="0" dur="2.5s" repeatCount="indefinite"></animate>
          </path>
          
          <!-- Nodes (Solid squares) -->
          <rect x="48" y="58" width="4" height="4" fill="#a1a1aa"></rect>
          <rect x="148" y="18" width="4" height="4" fill="#6366f1"></rect>
          <rect x="248" y="58" width="4" height="4" fill="#a1a1aa"></rect>
          <rect x="348" y="28" width="4" height="4" fill="#a1a1aa"></rect>
          <rect x="148" y="98" width="4" height="4" fill="#a1a1aa"></rect>

          <!-- Tactical Labels -->
          <text x="156" y="22" fill="#6366f1" font-size="8" font-family="monospace" letter-spacing="1">WH-ALPHA</text>
          <text x="256" y="62" fill="#a1a1aa" font-size="8" font-family="monospace" letter-spacing="1">WH-BETA</text>
        </svg>
      </div>

      <!-- Info Bar -->
      <div class="p-5 flex justify-between items-start flex-col gap-2">
        <span class="text-[10px] font-mono text-indigo-500 tracking-widest uppercase flex items-center gap-2">
          <span class="w-1 h-1 bg-indigo-500"></span>
          WMS-NATIVE
        </span>
        <h3 class="text-lg font-normal text-white tracking-wide leading-none mt-2">Global Node Network</h3>
      </div>

      <!-- Description -->
      <div class="px-5 pb-6 pt-1 flex-1 flex flex-col">
        <p class="text-sm font-light text-zinc-400 leading-relaxed font-sans mt-0">
          Deploy independent tracking instances across multiple warehouses. Each active node operates under strict organizational isolation.
        </p>
      </div>
    </div>

    <!-- Panel 2: Immutable Append Log -->
    <div class="relative border border-white/5 bg-zinc-950 flex flex-col group overflow-hidden">
      <!-- Tactical Corner Accents -->
      <div class="absolute top-0 left-0 w-2 h-2 border-t border-l border-white/40"></div>
      <div class="absolute top-0 right-0 w-2 h-2 border-t border-r border-white/40"></div>
      <div class="absolute bottom-0 left-0 w-2 h-2 border-b border-l border-white/40"></div>
      <div class="absolute bottom-0 right-0 w-2 h-2 border-b border-r border-white/40"></div>

      <!-- Graphic Area: Append Log -->
      <div class="relative border-b border-zinc-900 bg-zinc-900/20 flex flex-col justify-center h-[180px]">
        <div class="w-full h-full max-h-[140px] font-mono text-[10px] flex flex-col p-4 relative">
          <div class="grid grid-cols-3 gap-2 border-b border-zinc-800 pb-2 mb-2 w-full z-10 shrink-0">
            <span class="text-zinc-600">HASH</span>
            <span class="text-zinc-600 text-center">STATE</span>
            <span class="text-zinc-600 text-right">STATUS</span>
          </div>
          
          <div 
            class="relative flex-1 overflow-hidden w-full pt-1"
            style="mask-image: linear-gradient(to bottom, transparent, black 15%, black 85%, transparent); -webkit-mask-image: linear-gradient(to bottom, transparent, black 15%, black 85%, transparent);"
          >
            <div class="flex flex-col space-y-2 absolute top-0 left-0 right-0 animate-infinite-scroll-y">
              {[
                { id: "e3b0c442", op: "INIT_ENV", status: "OK" },
                { id: "9b12a551", op: "RECV_STK", status: "OK" },
                { id: "7c98f121", op: "ISU_ORDR", status: "OK" },
                { id: "4a33b919", op: "ADJ_AUDT", status: "OK" },
                { id: "f2a1b9c3", op: "SYNC_VLD", status: "OK" },
                { id: "8d44e712", op: "ISU_ORDR", status: "OK" },
                { id: "e3b0c442", op: "INIT_ENV", status: "OK" },
                { id: "9b12a551", op: "RECV_STK", status: "OK" },
                { id: "7c98f121", op: "ISU_ORDR", status: "OK" },
                { id: "4a33b919", op: "ADJ_AUDT", status: "OK" },
                { id: "f2a1b9c3", op: "SYNC_VLD", status: "OK" },
                { id: "8d44e712", op: "ISU_ORDR", status: "OK" },
              ].map((log, i) => (
                <div class="grid grid-cols-3 gap-2 items-center w-full">
                  <span class="text-zinc-500">[{log.id}]</span>
                  <span class="text-white text-center">{log.op}</span>
                  <span class="text-indigo-500 text-right">{log.status}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Info Bar -->
      <div class="p-5 flex justify-between items-start flex-col gap-2">
        <span class="text-[10px] font-mono text-indigo-500 tracking-widest uppercase flex items-center gap-2">
          <span class="w-1 h-1 bg-indigo-500"></span>
          TX-VERIFIED
        </span>
        <h3 class="text-lg font-normal text-white tracking-wide leading-none mt-2">Immutable Append Log</h3>
      </div>

      <!-- Description -->
      <div class="px-5 pb-6 pt-1 flex-1 flex flex-col">
        <p class="text-sm font-light text-zinc-400 leading-relaxed font-sans mt-0">
          Data history cannot be rewritten or corrupted. Every receipt, stock issuance, and manual adjustment is permanently hashed to the ledger.
        </p>
      </div>
    </div>

    <!-- Panel 3: Access Matrix -->
    <div class="relative border border-white/5 bg-zinc-950 flex flex-col group overflow-hidden">
      <!-- Tactical Corner Accents -->
      <div class="absolute top-0 left-0 w-2 h-2 border-t border-l border-white/40"></div>
      <div class="absolute top-0 right-0 w-2 h-2 border-t border-r border-white/40"></div>
      <div class="absolute bottom-0 left-0 w-2 h-2 border-b border-l border-white/40"></div>
      <div class="absolute bottom-0 right-0 w-2 h-2 border-b border-r border-white/40"></div>

      <!-- Graphic Area: Access Matrix -->
      <div class="relative border-b border-zinc-900 bg-zinc-900/20 flex flex-col justify-center h-[180px]">
        <div class="w-full h-full max-h-[140px] flex flex-col justify-center items-center overflow-hidden">
          <div class="grid grid-cols-4 gap-1 w-full max-w-[200px] relative">
            
            <!-- Scanning Line (CSS Animation) -->
            <div class="absolute top-[-10px] bottom-[-10px] w-[20px] bg-indigo-500/10 border-x border-indigo-500/30 animate-matrix-scan z-0 pointer-events-none" style="left: -10px;"></div>

            <div class="text-[8px] text-zinc-600 font-mono mb-2 z-10">ROLE</div>
            <div class="text-[8px] text-zinc-600 font-mono mb-2 text-center z-10">RD</div>
            <div class="text-[8px] text-zinc-600 font-mono mb-2 text-center z-10">WR</div>
            <div class="text-[8px] text-zinc-600 font-mono mb-2 text-center z-10">EX</div>
            
            {['SYS_ADM', 'WH_MGR', 'AUDIT'].map((role, rIdx) => (
              <>
                <div class={`text-[10px] font-mono leading-none flex items-center z-10 ${role === 'SYS_ADM' ? 'text-indigo-500' : 'text-zinc-500'}`}>{role}</div>
                {[1,2,3].map((col) => {
                  const hasAccess = rIdx === 0 || (rIdx === 1 && col < 3) || (rIdx === 2 && col === 1);
                  return (
                    <div class="flex justify-center items-center h-5 z-10">
                      <div class={`w-2 h-2 ${hasAccess ? (role === 'SYS_ADM' ? 'bg-indigo-500' : 'bg-white') : 'bg-transparent border border-white/10'} ${hasAccess ? 'animate-pulse' : ''}`} style={hasAccess ? `animation-duration: ${1 + (col * 0.5)}s;` : ''}></div>
                    </div>
                  );
                })}
              </>
            ))}
          </div>
        </div>
      </div>

      <!-- Info Bar -->
      <div class="p-5 flex justify-between items-start flex-col gap-2">
        <span class="text-[10px] font-mono text-indigo-500 tracking-widest uppercase flex items-center gap-2">
          <span class="w-1 h-1 bg-indigo-500"></span>
          RBAC-LOCKED
        </span>
        <h3 class="text-lg font-normal text-white tracking-wide leading-none mt-2">Role-Based Security Matrix</h3>
      </div>

      <!-- Description -->
      <div class="px-5 pb-6 pt-1 flex-1 flex flex-col">
        <p class="text-sm font-light text-zinc-400 leading-relaxed font-sans mt-0">
          Engineered access controls. Delegate precise read, write, and execution boundaries down to the individual operator level.
        </p>
      </div>
    </div>

    <!-- Panel 4: Real-Time Telemetry -->
    <div class="relative border border-white/5 bg-zinc-950 flex flex-col group overflow-hidden">
      <!-- Tactical Corner Accents -->
      <div class="absolute top-0 left-0 w-2 h-2 border-t border-l border-white/40"></div>
      <div class="absolute top-0 right-0 w-2 h-2 border-t border-r border-white/40"></div>
      <div class="absolute bottom-0 left-0 w-2 h-2 border-b border-l border-white/40"></div>
      <div class="absolute bottom-0 right-0 w-2 h-2 border-b border-r border-white/40"></div>

      <!-- Graphic Area: Precision Bars -->
      <div class="relative border-b border-zinc-900 bg-zinc-900/20 flex flex-col justify-center h-[180px]">
        <div class="w-full h-full max-h-[140px] flex items-end justify-between px-6 pt-10 relative">
          <div class="absolute top-4 left-6 border border-indigo-600/30 bg-indigo-600/5 px-2 py-0.5 text-[9px] font-mono text-indigo-500">
            LIVE_FEED
          </div>
          <!-- Grid line -->
          <div class="absolute top-1/2 left-0 w-full border-t border-dashed border-zinc-800"></div>

          {[40, 70, 45, 90, 65, 30, 80, 50, 60, 100, 30, 40].map((h, i) => {
            const hVar = Math.max(10, h - 30 + (Math.random() * 40));
            return (
            <div class="w-[6%] relative flex flex-col justify-end" style="height: 100%;">
              <div 
                class={`w-full border-t border-l border-r border-b-0 ${h === 100 ? 'bg-indigo-500 border-indigo-500' : 'bg-zinc-800 border-zinc-600'} animate-telemetry`}
                style={`--h: ${h}%; --h-var: ${hVar}%; animation-delay: ${i * 0.15}s; height: var(--h);`}
              ></div>
            </div>
          )})}
          <!-- Floor line -->
          <div class="absolute bottom-0 left-0 w-full border-t border-zinc-800"></div>
        </div>
      </div>

      <!-- Info Bar -->
      <div class="p-5 flex justify-between items-start flex-col gap-2">
        <span class="text-[10px] font-mono text-indigo-500 tracking-widest uppercase flex items-center gap-2">
          <span class="w-1 h-1 bg-indigo-500"></span>
          STREAMING
        </span>
        <h3 class="text-lg font-normal text-white tracking-wide leading-none mt-2">Real-Time Telemetry</h3>
      </div>

      <!-- Description -->
      <div class="px-5 pb-6 pt-1 flex-1 flex flex-col">
        <p class="text-sm font-light text-zinc-400 leading-relaxed font-sans mt-0">
          Instant throughput visibility without manual batch processing. Monitor inventory levels and systemic demand immediately as transactions settle.
        </p>
      </div>
    </div>

  </div>

</section>
