---
import SectionEyebrow from '../../components/ui/astro/SectionEyebrow.astro';
import OpBadge from '../../components/ui/astro/OpBadge.astro';

const steps = [
  {
    id: "01",
    model: "RECEIVE",
    title: "Inject Stock",
    description:
      "Initialize tracking on incoming items. The ledger strictly enforces positive entry constraints.",
  },
  {
    id: "02",
    model: "ADJUST",
    title: "Reconcile Differences",
    description:
      "Correct discrepancies with a mandatory validation block. No silent overwrites, ever.",
  },
  {
    id: "03",
    model: "ISSUE",
    title: "Deploy Assets",
    description:
      "Decrement stock bound to employees or locations. Emits a verifiable exit trace.",
  },
];
---

<section class="px-6 py-32 w-full border-y border-zinc-900 bg-black relative z-10 overflow-hidden">
  <div class="max-w-[1600px] w-full mx-auto flex flex-col xl:flex-row gap-16 relative z-10">
    <!-- Left Column: Text -->
    <div class="xl:w-1/3 flex flex-col justify-start pt-2">
      <div class="border-l-2 border-indigo-500 pl-6 mb-8">
        <SectionEyebrow class="mb-3">
          Execution Protocols
        </SectionEyebrow>
        <h2 class="text-3xl md:text-4xl font-light text-white tracking-normal leading-[1.1]">
          Anatomy of a<br />
          movement.
        </h2>
      </div>
      <div class="text-sm text-zinc-400 font-mono max-w-md bg-zinc-950 p-5 border border-zinc-900 relative">
        <span class="absolute top-0 left-0 w-2 h-2 border-t border-l border-zinc-800"></span>
        <span class="absolute bottom-0 right-0 w-2 h-2 border-b border-r border-zinc-800"></span>
        Bodega rejects the concept of arbitrary database editing. Every
        inventory change relies on a strict, immutable operation model.
      </div>
    </div>

    <!-- Right Column: Execution Stack Matrix -->
    <div class="xl:w-2/3">
      <div class="flex flex-col border border-zinc-900 bg-zinc-950">
        <!-- Table Header -->
        <div class="hidden sm:grid grid-cols-[80px_120px_1fr] border-b border-zinc-900 p-2 bg-black/40">
          <div class="text-[9px] font-mono text-zinc-700 uppercase tracking-widest text-center">
            SEQ_ID
          </div>
          <div class="text-[9px] font-mono text-zinc-700 uppercase tracking-widest text-center">
            VECTOR
          </div>
          <div class="text-[9px] font-mono text-zinc-700 uppercase tracking-widest pl-6">
            PAYLOAD_DIRECTIVE
          </div>
        </div>

        <!-- Table Body -->
        {steps.map((s, idx) => (
          <div
            class="grid grid-cols-1 sm:grid-cols-[80px_120px_1fr] border-b border-zinc-900/50 last:border-0 relative group"
          >
            <!-- Indigo left accent on hover -->
            <div class="absolute left-0 top-0 bottom-0 w-[2px] bg-indigo-500 opacity-0 group-hover:opacity-100 transition-opacity"></div>

            <!-- Seq ID -->
            <div class="p-4 sm:border-r border-b sm:border-b-0 border-zinc-900 flex items-start justify-center pt-6 sm:pt-8 bg-black/40">
              <span class="font-mono text-xs text-zinc-700 group-hover:text-indigo-400 transition-colors">
                [{s.id}]
              </span>
            </div>

            <!-- Graphic -->
            <div class="p-4 sm:border-r border-b sm:border-b-0 border-zinc-900 flex items-center justify-center bg-black/20">
              {idx === 0 && (
                <!-- RECEIVE Graphic -->
                <svg class="w-14 h-14" viewBox="0 0 100 100" fill="none">
                  <!-- Box -->
                  <rect x="25" y="40" width="50" height="50" stroke="#52525b" stroke-width="1"></rect>
                  <rect x="30" y="45" width="40" height="40" stroke="#3f3f46" stroke-width="1" stroke-dasharray="2 2"></rect>
                  <!-- Animated Inject line -->
                  <path d="M 50 0 L 50 40" stroke="#3730a3" stroke-width="1" stroke-dasharray="4 4"></path>
                  <path d="M 50 0 L 50 40" stroke="#6366f1" stroke-width="2" stroke-dasharray="10 50">
                    <animate attributeName="stroke-dashoffset" from="-60" to="0" dur="1.5s" repeatCount="indefinite"></animate>
                  </path>
                  <!-- Arrowhead -->
                  <path d="M 45 35 L 50 40 L 55 35" stroke="#6366f1" stroke-width="1"></path>
                </svg>
              )}
              {idx === 1 && (
                <!-- ADJUST Graphic -->
                <svg class="w-14 h-14" viewBox="0 0 100 100" fill="none">
                  <!-- Radar/Target -->
                  <circle cx="50" cy="50" r="30" stroke="#52525b" stroke-width="1"></circle>
                  <circle cx="50" cy="50" r="20" stroke="#3f3f46" stroke-width="1" stroke-dasharray="2 2"></circle>
                  <circle cx="50" cy="50" r="4" fill="#6366f1"></circle>
                  <path d="M 50 10 L 50 30 M 50 70 L 50 90 M 10 50 L 30 50 M 70 50 L 90 50" stroke="#6366f1" stroke-width="1" opacity="0.5"></path>
                  <!-- Active Scan line -->
                  <circle cx="50" cy="50" r="30" stroke="#6366f1" stroke-width="1" stroke-dasharray="10 180" stroke-linecap="round">
                    <animateTransform attributeName="transform" type="rotate" from="0 50 50" to="360 50 50" dur="3s" repeatCount="indefinite"></animateTransform>
                  </circle>
                </svg>
              )}
              {idx === 2 && (
                <!-- ISSUE Graphic -->
                <svg class="w-14 h-14" viewBox="0 0 100 100" fill="none">
                  <!-- Box -->
                  <rect x="25" y="10" width="50" height="50" stroke="#52525b" stroke-width="1"></rect>
                  <!-- Animated Extract line -->
                  <path d="M 50 60 L 50 100" stroke="#3730a3" stroke-width="1" stroke-dasharray="4 4"></path>
                  <path d="M 50 60 L 50 100" stroke="#6366f1" stroke-width="2" stroke-dasharray="10 50">
                    <animate attributeName="stroke-dashoffset" from="-60" to="0" dur="1.5s" repeatCount="indefinite"></animate>
                  </path>
                  <!-- Arrowhead -->
                  <path d="M 45 95 L 50 100 L 55 95" stroke="#6366f1" stroke-width="1"></path>
                </svg>
              )}
            </div>

            <!-- Payload -->
            <div class="p-6 sm:p-8 flex flex-col justify-center group-hover:bg-zinc-900/30 transition-colors">
              <div class="flex items-center gap-3 mb-3">
                <h3 class="text-base font-light text-white">
                  {s.title}
                </h3>
                <OpBadge class="bg-black">
                  OP:{s.model}
                </OpBadge>
              </div>
              <p class="text-zinc-500 font-mono text-xs leading-relaxed max-w-lg">
                {s.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
